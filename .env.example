# ============================================================
# FAKE NEWS AI — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# --- DATABASE ---
DATABASE_URL=postgresql://user:password@localhost:5432/fakenews_db
# For Supabase:
# DATABASE_URL=postgresql://postgres:[password]@db.[project].supabase.co:5432/postgres

# --- BACKEND ---
SECRET_KEY=your-super-secret-jwt-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
BACKEND_URL=http://localhost:8000
ALLOWED_ORIGINS=http://localhost:3000,https://your-frontend.vercel.app

# --- FRONTEND (Next.js public vars) ---
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=FakeNewsAI
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- NEWS APIs (Free Tiers) ---
NEWS_API_KEY=your_newsapi_key          # newsapi.org — free 100 req/day
GNEWS_API_KEY=your_gnews_key           # gnews.io — free 100 req/day
MEDIASTACK_API_KEY=your_mediastack_key # mediastack.com — free 500 req/month

# --- HUGGINGFACE ---
HUGGINGFACE_API_TOKEN=hf_your_token_here

# --- AI MODEL PATHS ---
BERT_MODEL_PATH=./ai_models/bert/saved_model
ROBERTA_MODEL_PATH=./ai_models/roberta/saved_model
BERT_MULTILINGUAL_MODEL_PATH=./ai_models/bert_multilingual/saved_model
LSTM_MODEL_PATH=./ai_models/lstm/saved_model
LOGISTIC_MODEL_PATH=./ai_models/logistic_regression/saved_model

# --- ENSEMBLE WEIGHTS (must sum to 1.0) ---
BERT_WEIGHT=0.30
ROBERTA_WEIGHT=0.25
BERT_MULTILINGUAL_WEIGHT=0.20
LSTM_WEIGHT=0.15
LOGISTIC_WEIGHT=0.10

# --- FILE UPLOAD ---
MAX_UPLOAD_SIZE_MB=10
UPLOAD_DIR=./uploads

# --- EMAIL (Contact Form) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASSWORD=your_app_password

# --- ADMIN ---
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_this_password

# --- RATE LIMITING ---
RATE_LIMIT_PER_MINUTE=30
